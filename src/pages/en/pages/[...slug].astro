---
import ContentLayout from '@/layouts/ContentLayout.astro'
import { getNotionPageContent, getNotionPages } from '@/lib/notion'
import { getDescriptionFromMarkdown, renderNotionMarkdown } from '@/utils/notion-markdown'

export const prerender = true

export async function getStaticPaths() {
  const pages = (await getNotionPages()).filter((page) => page.lang === 'en')

  return pages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }))
}

const { page } = Astro.props
const markdown = await getNotionPageContent(page.sourcePageId)
const { html, headings } = await renderNotionMarkdown(markdown)
const description = getDescriptionFromMarkdown(markdown, page.title)
---

<ContentLayout meta={{ title: page.title, description }} back='/en'>
  <Fragment slot='header'>
    <h1 class='text-2xl font-medium sm:mb-2 sm:text-3xl'>{page.title}</h1>
    <div class='mt-3 italic'>
      <blockquote class='text-sm text-muted-foreground'><q>{description}</q></blockquote>
    </div>
    <div class='mt-4 w-1/2 border-t max-lg:mx-auto sm:mt-6 sm:w-1/3'></div>
  </Fragment>

  {
    headings.length > 0 && (
      <ul slot='sidebar' class='space-y-2 text-sm text-muted-foreground'>
        {headings.map((heading) => (
          <li style={`padding-left:${Math.max(heading.depth - 2, 0)}rem`}>
            <a class='hover:text-foreground' href={`#${heading.slug}`}>
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    )
  }

  <Fragment set:html={html} />
</ContentLayout>
