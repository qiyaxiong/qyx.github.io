---
import { Image } from 'astro:assets'
import { Button, Icon, Label } from '@/components/user'
import GitHubActivityCalendar from '@/components/home/GitHubActivityCalendar.astro'
import PageLayout from '@/layouts/BaseLayout.astro'
import Section from '@/components/home/Section.astro'
import BlogStats from '@/components/home/BlogStats.astro'
import avatar from '@/assets/avatar.jpg'
import config from '@/site-config'
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#659EB966'>
  <main class='flex w-full flex-col items-center'>
    <section class='animate mb-10 flex flex-col items-center gap-y-7' id='content-header'>
      <div class='flex flex-row items-center gap-x-6'>
        <Image
          src={avatar}
          alt='profile'
          class='h-36 w-auto rounded-lg border p-1'
          loading='eager'
        />
        <div class='flex flex-col gap-y-4'>
          <h1 class='text-3xl font-bold'>{config.author}</h1>
          <div class='flex flex-wrap gap-x-1 gap-y-1'>
            {config.personal?.location && (
              <Label title={config.personal.location}>
                <Icon name='location' class='size-4' slot='icon' />
              </Label>
            )}
            {config.personal?.githubUsername && (
              <Label
                title='Github'
                as='a'
                href={`https://github.com/${config.personal.githubUsername}`}
                target='_blank'
              >
                <Icon name='github' class='size-4' slot='icon' />
              </Label>
            )}
            {config.personal?.email && (
              <Label title='Email' as='a' href={`mailto:${config.personal.email}`}>
                <Icon name='email' class='size-4' slot='icon' />
              </Label>
            )}
            {config.personal?.googleScholar && (
              <Label title='Scholar' as='a' href={config.personal.googleScholar}>
                <Icon name='earth' class='size-4' slot='icon' />
              </Label>
            )}
          </div>
        </div>
      </div>

    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      <Section title='About'>
        <p class='text-muted-foreground'>
          {config.personal?.bio ||
            '我是你的名字，一个喜欢写代码、做系统，也喜欢把想法慢慢整理成文字的人。这个网站记录的，不只是完成的结果，也包括仍在继续的学习、思考与构建。这里有文章，有笔记，有项目，也有我正在慢慢形成的技术观和方法论。'}
        </p>
        <Button title='More about me' class='w-fit self-end' href='/about' style='ahead' />
      </Section>
      <Section title='Statistics'>
        <BlogStats blogStartDate={config.personal?.blogStartDate ? new Date(config.personal.blogStartDate) : new Date('2024-06-15')} />
      </Section>
      {config.personal?.githubUsername && (
        <GitHubActivityCalendar username={config.personal.githubUsername}/>
      )}
    </div>
  </main>
</PageLayout>
