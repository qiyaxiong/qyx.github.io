---
import { getNotionProjects } from '@/lib/notion'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'
import config from '@/site-config'

const headings = [
  { depth: 2, slug: 'projects', text: 'Projects' }
]

const projects = (await getNotionProjects())
  .filter((project) => project.lang === 'zh')
  .sort((a, b) => (a.order ?? 0) - (b.order ?? 0))
  .map((project) => ({
    name: project.title,
    description: project.description || '',
    links: [
      project.site ? { type: 'site', href: project.site } : null,
      project.github ? { type: 'github', href: project.github } : null,
      project.doc ? { type: 'doc', href: project.doc } : null,
      project.release ? { type: 'release', href: project.release } : null
    ].filter((link): link is { type: string; href: string } => link !== null)
  }))
---

<PageLayout title='Projects' {headings} info={{ slug: '/projects', hideComment: true }}>
  <h2 id='projects' class='mb-8 text-2xl font-semibold'>Projects</h2>
  <ProjectSection project={projects} />
</PageLayout>

<script
  is:inline
  type='module'
  data-astro-rerun
  define:vars={{ npmCDN: config.npmCDN, walineServer: config.integ.waline.server }}
>
  const normalizePath = (path) => {
    if (path === '/') return path
    return path.endsWith('/') ? path.slice(0, -1) : path
  }

  const loadPageviewCount = async () => {
    const pageview = await import(`${npmCDN}/@waline/client@v3/dist/pageview.js`)
    pageview.pageviewCount({
      serverURL: walineServer,
      path: normalizePath(window.location.pathname)
    })
  }

  await loadPageviewCount()
</script>
