---
import type { MarkdownHeading } from 'astro'
import { render, type CollectionEntry } from 'astro:content'
import {
  getBlogCollection,
  sortMDByDate,
  type BlogCollectionEntry,
  type BlogPostEntry
} from '@/server'
import type { Root } from 'mdast'
import rehypeKatex from 'rehype-katex'
import rehypeStringify from 'rehype-stringify'
import remarkGfm from 'remark-gfm'
import remarkMath from 'remark-math'
import remarkParse from 'remark-parse'
import remarkRehype from 'remark-rehype'
import { unified } from 'unified'
import { visit } from 'unist-util-visit'

import PostLayout from '@/layouts/BlogPost.astro'
import mdastToString from '@/utils/mdast-util-to-string'
import { renderNotionEmbeds } from '@/utils/notion-embeds'
import getReadingTime from '@/utils/reading-time'
import rehypeImagePolicy from '@/utils/rehype-image-policy'

import { getNotionPageContent } from '../../lib/notion'

function slugifyHeading(text: string): string {
  return text
    .trim()
    .toLowerCase()
    .replace(/[`~!@#$%^&*()+=[\]{}|\\:;"'<>,.?/]/g, '')
    .replace(/\s+/g, '-')
}

function getDescriptionFromMarkdown(markdown: string, fallback: string): string {
  const normalized = markdown
    .replace(/!\[[^\]]*]\([^)]+\)/g, '')
    .replace(/\[([^\]]+)]\([^)]+\)/g, '$1')
    .replace(/[#>*_`~-]/g, ' ')
    .replace(/\s+/g, ' ')
    .trim()

  return normalized.slice(0, 160) || fallback
}

async function renderNotionMarkdown(markdown: string): Promise<{
  html: string
  headings: MarkdownHeading[]
  remarkPluginFrontmatter: Record<string, unknown>
}> {
  const headings: MarkdownHeading[] = []
  let minutesRead = '1 min read'
  let words = 0

  const processor = unified()
    .use(remarkParse)
    .use(remarkGfm)
    .use(remarkMath)
    .use(() => {
      return (tree: Root) => {
        const plainText = mdastToString(tree)
        const readingTime = getReadingTime(plainText)
        minutesRead = readingTime.text
        words = readingTime.words

        visit(tree, 'heading', (node) => {
          const text = mdastToString(node, { includeHtml: false }).trim()
          if (!text) return

          const slug = slugifyHeading(text)
          node.data = {
            ...(node.data || {}),
            hProperties: {
              ...((node.data && node.data.hProperties) || {}),
              id: slug
            }
          }

          headings.push({
            depth: node.depth,
            slug,
            text
          })
        })
      }
    })
    .use(remarkRehype)
    .use(rehypeImagePolicy)
    .use(rehypeKatex)
    .use(rehypeStringify)

  const file = await processor.process(markdown)

  return {
    html: String(file),
    headings,
    remarkPluginFrontmatter: {
      minutesRead,
      words
    }
  }
}

const { id } = Astro.params

const allPosts = sortMDByDate(await getBlogCollection())

const post = allPosts.find((item) => item.id === id)

if (!post) {
  return Astro.redirect('/404')
}

function isNotionPostEntry(
  entry: BlogCollectionEntry
): entry is BlogPostEntry & { sourcePageId: string } {
  return typeof (entry as BlogPostEntry).sourcePageId === 'string'
}

let html = ''
let Content: any
let headings: MarkdownHeading[] = []
let remarkPluginFrontmatter: Record<string, unknown> = {}
let renderedPost: BlogCollectionEntry = post
let renderedPosts: BlogCollectionEntry[] = allPosts

if (isNotionPostEntry(post)) {
  const markdown = await getNotionPageContent(post.sourcePageId)
  const rendered = await renderNotionMarkdown(markdown)
  const description = post.data.description || getDescriptionFromMarkdown(markdown, post.data.title)

  html = renderNotionEmbeds(rendered.html)
  headings = rendered.headings
  remarkPluginFrontmatter = rendered.remarkPluginFrontmatter
  renderedPost = {
    ...post,
    data: {
      ...post.data,
      description
    }
  }
  renderedPosts = allPosts.map((item) => (item.id === post.id ? renderedPost : item))
} else {
  const rendered = await render(post as CollectionEntry<'blog'>)
  Content = rendered.Content
  headings = rendered.headings
  remarkPluginFrontmatter = rendered.remarkPluginFrontmatter
}
---

<PostLayout
  post={renderedPost as any}
  posts={renderedPosts as any}
  {headings}
  {remarkPluginFrontmatter}
>
  {Content ? <Content /> : <Fragment set:html={html} />}
</PostLayout>
