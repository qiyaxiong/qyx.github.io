---
import { getBlogCollection, getUniqueCategoriesWithCount, sortMDByDate } from '@/server'

import PageLayout from '@/layouts/BaseLayout.astro'
import { PostPreview } from '@/components/pages'
import { Button } from '@/components/user'
import { getCategoryLabel } from '@/utils/blog-categories'

export const prerender = true

const allPosts = sortMDByDate(await getBlogCollection())
const categories = getUniqueCategoriesWithCount(allPosts)

const meta = {
  description: 'Browse all blog posts',
  title: 'Blog'
}
---

<PageLayout {meta}>
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate'>
      <h1 class='mb-4 text-3xl font-medium'>Blog</h1>
      {
        !!categories.length && (
          <ul class='mb-6 flex flex-wrap gap-2'>
            {categories.map(([category, count]) => (
              <li>
                <Button
                  title={`${getCategoryLabel(category)} (${count})`}
                  href={`/blog/${category}`}
                  style='pill'
                />
              </li>
            ))}
          </ul>
        )
      }
    </div>

    {allPosts.length === 0 && <p>No posts yet.</p>}

    <section id='content' class='animate' aria-label='All blog post list'>
      <ul class='flex flex-col gap-y-3 text-start'>
        {allPosts.map((post) => <PostPreview as='h2' {post} detailed />)}
      </ul>
    </section>
  </main>
</PageLayout>
