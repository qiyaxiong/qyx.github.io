NOTION_API_KEY=""

NOTION_REGISTRY_DATABASE_ID=""

# Optional: GitHub personal access token for the homepage contribution calendar.
# Without this, the site shows public contributions only.
GITHUB_TOKEN=""

# Optional: Notion webhook -> rebuild blog after Notion content changes.
# 1. Create a Notion webhook subscription pointing to /api/notion-sync.
# 2. Paste Notion's verification token here after subscription verification.
NOTION_WEBHOOK_VERIFICATION_TOKEN=""

# Vercel Deploy Hook URL, or any build hook URL that accepts POST.
VERCEL_DEPLOY_HOOK_URL=""
